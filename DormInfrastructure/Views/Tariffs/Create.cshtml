@model DormDomain.Model.Tariff

@{
    ViewData["Title"] = "Create";
}

<h1>Створити тариф </h1>


<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="TariffsName" class="control-label"></label>
                <input asp-for="TariffsName" class="form-control" />
                <span asp-validation-for="TariffsName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label  asp-for="PricePerMonth" class="control-label"></label>
                <input type="number"  asp-for="PricePerMonth" class="form-control" />
                <span asp-validation-for="PricePerMonth" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
